#!/usr/bin/env bash

new_alias='alias tf="terraform"'

# Check if .bash_profile exists
if [ -f ~/.bash_profile ]; then
    # Check if the alias already exists in .bash_profile
    if ! grep -q "$new_alias" ~/.bash_profile; then
        # Add the alias to .bash_profile
        echo -e "\n# Adding alias for Terraform" >> ~/.bash_profile
        echo "$new_alias" >> ~/.bash_profile
        echo "Alias added successfully. Please restart your terminal or run 'source ~/.bash_profile'."
    else
        echo "Alias already exists in .bash_profile."
    fi
else
    echo "Error: .bash_profile not found. Please create one and run the script again."
fi